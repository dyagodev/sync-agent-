{
  "name": "ferro-cianorte-sync-agent",
  "version": "1.4.0",
  "private": true,
  "description": "Agente que monitora o Postgres do Link Pro (Cervantes) e replica as vendas no Ferro Cianorte.",
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/win/agente.exe && node scripts/build-windows.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist/win"
  }
}
