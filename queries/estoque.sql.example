-- AJUSTE AQUI: troque pela tabela real de estoque do Link Pro. Esta query é
-- opcional — se o arquivo "estoque.sql" (sem .example) não existir, o agente
-- simplesmente não sincroniza estoque, só vendas.
--
-- Serve pra pegar ajustes de estoque feitos SEM venda (contagem manual,
-- balança, correção, entrada de mercadoria lançada direto no Link Pro etc.),
-- que senão nunca apareceriam pro agente (que só olha a tabela de vendas).
--
-- Contrato que o agente espera desta query (não pode mudar os apelidos):
--   loja_externa    -> identificador da loja/filial no Link Pro
--   codigo_barras   -> usado para casar com o produto cadastrado no Ferro Cianorte
--   quantidade      -> quantidade ATUAL em estoque (valor absoluto, não delta) —
--                       o agente simplesmente define esse valor no Ferro Cianorte,
--                       sobrescrevendo o que estiver lá, pra nunca ficar com furo.
--   atualizado_em   -> timestamp da última atualização desse registro de estoque
--
-- O parâmetro $1 é o timestamp da última verificação (época Unix 0 na primeira
-- execução, ou seja: a primeira rodada traz o estoque inteiro).
select
  e.loja_id         as loja_externa,
  p.codigo_barras   as codigo_barras,
  e.quantidade      as quantidade,
  e.atualizado_em   as atualizado_em
from estoque e
join produtos p on p.id = e.produto_id
where e.atualizado_em > $1
order by e.atualizado_em asc
limit 500;
