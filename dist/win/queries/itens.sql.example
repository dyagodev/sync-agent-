-- AJUSTE AQUI: troque pelos nomes reais das tabelas de item de venda e produto.
--
-- Contrato que o agente espera desta query:
--   venda_id       -> deve bater com o "id" retornado em vendas.sql
--   codigo_barras  -> usado para casar com o produto já cadastrado no Ferro Cianorte
--   quantidade     -> numérico
--   preco_unitario -> preço efetivamente cobrado no item (não o preço de tabela)
--
-- O parâmetro $1 é um array com os ids de venda do lote atual.
select
  iv.venda_id        as venda_id,
  p.codigo_barras    as codigo_barras,
  iv.quantidade      as quantidade,
  iv.preco_unitario  as preco_unitario
from itens_venda iv
join produtos p on p.id = iv.produto_id
where iv.venda_id = any($1::bigint[]);
