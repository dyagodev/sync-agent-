# Este arquivo é só referência: normalmente você NÃO precisa criar/editar um
# .env na mão. Rode `npm start` e configure tudo pela janela em
# http://localhost:4848 — ela gera o .env sozinha. Use este exemplo apenas se
# preferir editar o arquivo diretamente.

# --- Postgres do sistema de origem (Link Pro / Cervantes) ---
SOURCE_PG_HOST=127.0.0.1
SOURCE_PG_PORT=5432
SOURCE_PG_DATABASE=linkpro
SOURCE_PG_USER=leitura
SOURCE_PG_PASSWORD=troque-me
# Ative se o Postgres de origem exigir SSL.
SOURCE_PG_SSL=false

# --- API do Ferro Cianorte ---
FERRO_CIANORTE_API_URL=http://127.0.0.1:8000/api
# Credenciais de um usuário ADMIN dedicado a essa integração, criado em
# /admin/funcionarios. Precisa ser admin (não vendedor) porque o Link Pro é
# multiloja: cada venda pode pertencer a uma loja nossa diferente, e só admin
# pode informar explicitamente em qual loja registrar a venda.
FERRO_CIANORTE_EMAIL=integracao.linkpro@ferrocianorte.test
FERRO_CIANORTE_PASSWORD=troque-me

# --- Comportamento do agente ---
# Intervalo entre cada verificação de vendas novas, em milissegundos.
POLL_INTERVAL_MS=15000
# Onde o agente guarda o id da última venda processada (arquivo local).
CHECKPOINT_FILE=./checkpoint.json
# Porta onde a janela de configuração (http://localhost:PORTA) fica disponível.
CONFIG_UI_PORT=4848

# Mapeia o identificador de loja do Link Pro (chave) para o id da loja no
# Ferro Cianorte (valor) — coluna "loja_externa" da query vendas.sql/estoque.sql.
# No schema real confirmado (InkDB), tudo indica um Postgres por loja (ver
# README), então cada instância do agente normalmente só precisa de UMA
# entrada aqui (o valor fixo '1' usado nas queries reais).
MAPA_LOJAS={"1":"1"}

# Mapeia os textos de forma de pagamento do Link Pro pro nosso enum
# (dinheiro, cartao, pix, boleto, cheque, crediario). No schema real
# confirmado, "negociacao_parcela.forma_pagamento" já vem em texto — ajuste
# maiúsculas/acentos conforme a amostra real (rode "Gerar log da estrutura do
# banco" pra ver os textos exatos usados nessa instalação).
MAPA_FORMAS_PAGAMENTO={"Dinheiro":"dinheiro","Cartao":"cartao","Pix":"pix","Boleto":"boleto","Cheque":"cheque","Crediario":"crediario"}
